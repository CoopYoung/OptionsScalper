# ── Alpaca (Required) ──────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex

# ── Trading Mode ──────────────────────────────────────────
TRADING_MODE=paper

# ── Underlyings ───────────────────────────────────────────
UNDERLYINGS=SPY,QQQ,IWM

# ── Telegram Alerts (Optional) ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Reddit Sentiment (Optional) ──────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=options-scalper/1.0

# ── GEX Data (Optional) ──────────────────────────────────
SQUEEZEMETRICS_API_KEY=

# ── Strategy ──────────────────────────────────────────────
TARGET_DELTA=0.30
MIN_PREMIUM=0.50
MAX_PREMIUM=5.00
MIN_SPREAD_RATIO=0.90
SIGNAL_CONFIDENCE_THRESHOLD=55
ENTRY_START=09:45
ENTRY_CUTOFF=14:30
HARD_CLOSE=15:15

# ── Risk ──────────────────────────────────────────────────
KELLY_FRACTION=0.20
MAX_POSITION_PCT=0.05
MAX_PORTFOLIO_EXPOSURE=0.30
DAILY_DRAWDOWN_HALT=0.08
MAX_CONTRACTS_PER_TRADE=10
MAX_POSITIONS_PER_UNDERLYING=3

# ── Greeks Limits ─────────────────────────────────────────
MAX_PORTFOLIO_DELTA=50.0
MAX_PORTFOLIO_GAMMA=20.0
MAX_PORTFOLIO_THETA=-100.0
MAX_PORTFOLIO_VEGA=30.0

# ── Exit Parameters ──────────────────────────────────────
PT_PROFIT_TARGET_PCT=0.50
SL_STOP_LOSS_PCT=0.30
SL_TRAILING_PCT=0.20

# ── Ensemble Weights (should sum to 1.0) ─────────────────
WEIGHT_TECHNICAL=0.25
WEIGHT_TICK_MOMENTUM=0.20
WEIGHT_GEX=0.15
WEIGHT_FLOW=0.15
WEIGHT_VIX=0.10
WEIGHT_INTERNALS=0.10
WEIGHT_SENTIMENT=0.05

# ── Database ──────────────────────────────────────────────
SQLITE_DB_PATH=data/bot.db

# ── Web Dashboard ────────────────────────────────────────
WEB_PORT=8090
WEB_ENABLED=true
